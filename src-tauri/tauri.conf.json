{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UtaiSynthesizer",
  "mainBinaryName": "UtaiSynthesizer",
  "version": "0.8.3",
  "identifier": "com.utaisynthesizer.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$APPLOCALDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../bin/ffmpeg.exe": "ffmpeg.exe",
      "../runtime/ort/onnxruntime.dll": "runtime/ort/onnxruntime.dll",
      "../runtime/ort/onnxruntime_providers_shared.dll": "runtime/ort/onnxruntime_providers_shared.dll",
      "../runtime/ort/DirectML.dll": "runtime/ort/DirectML.dll",
      "../data/dictionaries/zh_syllables.tsv": "data/dictionaries/zh_syllables.tsv",
      "../data/dictionaries/zh_chars.tsv": "data/dictionaries/zh_chars.tsv",
      "../data/dictionaries/zh_phrases.tsv": "data/dictionaries/zh_phrases.tsv",
      "../data/dictionaries/en.tsv": "data/dictionaries/en.tsv",
      "../data/dictionaries/de.tsv": "data/dictionaries/de.tsv",
      "../data/dictionaries/fr.tsv": "data/dictionaries/fr.tsv",
      "../data/dictionaries/es.tsv": "data/dictionaries/es.tsv",
      "../data/dictionaries/it.tsv": "data/dictionaries/it.tsv",
      "../converter/convert.py": "converter/convert.py",
      "../converter/extract_index.py": "converter/extract_index.py",
      "../converter/export_cluster.py": "converter/export_cluster.py",
      "../converter/export_diffusion.py": "converter/export_diffusion.py",
      "../converter/export_nsf_hifigan.py": "converter/export_nsf_hifigan.py",
      "../converter/onnx_fp16.py": "converter/onnx_fp16.py",
      "../converter/architectures/": "converter/architectures/",
      "../training/utai_train/": "training/utai_train/",
      "../training/assets/": "training/assets/"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./installer/hooks.nsh",
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "languages": ["English", "SimpChinese", "Japanese"],
        "displayLanguageSelector": true,
        "compression": "lzma"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {},
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhFRThFMkNFNTA1QzRCQTEKUldTaFMxeFF6dUxvanNDNE5sdk82L0lkRXlLS2xJSmdyZG5MWXNUS0pid1oyYVFEcmc2WEpRck0K",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
