{
  "identifier": "default",
  "description": "Default capability set for UTAI",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-hide",
    "core:window:allow-minimize",
    "core:window:allow-show",
    "core:window:allow-set-title",
    "dialog:default",
    "fs:default",
    "shell:default",
    "window-state:default"
  ]
}
